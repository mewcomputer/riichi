RIICHI_API_ADDR=127.0.0.1:3000
RIICHI_DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/riichi
RIICHI_DATABASE_MAX_CONNECTIONS=10
# Attachment bytes use the local filesystem by default. Set backend=s3 for an
# S3-compatible provider such as MinIO or a managed object store.
RIICHI_ATTACHMENT_BACKEND=local
RIICHI_ATTACHMENT_DIR=./data/attachments
RIICHI_ATTACHMENT_S3_ENDPOINT=http://127.0.0.1:9000
RIICHI_ATTACHMENT_S3_BUCKET=riichi
RIICHI_ATTACHMENT_S3_REGION=us-east-1
RIICHI_ATTACHMENT_S3_ACCESS_KEY_ID=replace-me
RIICHI_ATTACHMENT_S3_SECRET_ACCESS_KEY=replace-me
RIICHI_ATTACHMENT_S3_ALLOW_HTTP=true
# Set RIICHI_S3_TEST_MANAGED=true only when running the managed restore check.
# It uses the attachment S3 settings above and writes to a unique temporary prefix.
RIICHI_S3_TEST_MANAGED=false

# Use the exact issuer URL advertised by the Pocket ID discovery document.
RIICHI_OIDC_ISSUER_URL=https://idp.example.test
RIICHI_OIDC_CLIENT_ID=replace-me
RIICHI_OIDC_CLIENT_SECRET=replace-me
# The browser reaches this through Vite's /auth proxy while the API listens on :3000.
RIICHI_OIDC_REDIRECT_URL=http://127.0.0.1:5173/auth/callback
# Keep false only for local HTTP development. HTTPS deployments must use true.
RIICHI_AUTH_COOKIE_SECURE=false
RIICHI_AUTH_SESSION_DAYS=7
RIICHI_AUTH_LOGIN_STATE_MINUTES=10

# Optional metadata read replication. Leave unset to use TanStack Query.
VITE_ELECTRIC_SYNC_ENABLED=false
RIICHI_ELECTRIC_URL=http://127.0.0.1:5133
RIICHI_ELECTRIC_SOURCE_SECRET=dev-electric-secret
# `just start-db` enables logical replication on the local Postgres container.
# Override this only when Electric runs outside the local Docker setup.
RIICHI_ELECTRIC_PORT=5133

# GitHub issue import and webhook delivery. Keep the token and secret out of logs and database content.
RIICHI_GITHUB_TOKEN=replace-me
RIICHI_GITHUB_API_BASE_URL=https://api.github.com
RIICHI_GITHUB_WEBHOOK_SECRET=replace-me
RIICHI_GITHUB_PROJECT_ID=replace-me
